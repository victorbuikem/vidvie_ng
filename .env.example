# Drizzle
# Replace with your DB credentials!
DATABASE_URL="postgres://user:password@host:port/db-name"

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Flutterwave
# Get your keys at https://dashboard.flutterwave.com/settings/apis
FLW_SECRET_KEY=""
FLW_PUBLIC_KEY=""
FLW_SECRET_HASH=""

# Railway Buckets (S3-compatible)
RAILWAY_BUCKET_ENDPOINT=""
RAILWAY_BUCKET_NAME=""
RAILWAY_BUCKET_ACCESS_KEY_ID=""
RAILWAY_BUCKET_SECRET_ACCESS_KEY=""

# Email (SMTP via Nodemailer)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="VIDVIE Store <noreply@vidvie.store>"
